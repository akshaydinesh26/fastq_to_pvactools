//     // }
//     // withName: 'NFCORE_RNASEQ' {
//     //     publishDir = "$params.outdir/rnaseq"
//     // }
//     // withName: 'NFCORE_RNAFUSION' {
//     //     publishDir = "$params.outdir/rnafusion"
//     // }
//     // withName: 'NFCORE_HLATYPING' {
//     //     publishDir = "$params.outdir/hlatyping"
//     // }
//     withName: 'TRONFLOW' {
//         publishDir = { "$params.outdir/tronflow" }
//     }
// }

timeline {
  enabled = true
  file = "${params.output_final}/reports/timeline.html"
}

trace {
  enabled = true
  file = "${params.output_final}/reports/trace.txt"
}

report {
  enabled = true
  file = "${params.output_final}/reports/report.html"
}

